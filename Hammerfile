# run with bin/hammer

task :test do
  desc 'Run the full test suite (minitest, no Rake)'
  proc do
    $LOAD_PATH.unshift File.expand_path('lib'), File.expand_path('test')
    require 'minitest/autorun'
    Dir['test/*_test.rb'].sort.each { |f| require_relative File.expand_path(f) }
    # minitest's at_exit hook runs the suite and sets the process exit code
  end
end

task :gem do
  desc <<~TXT
    Gem helpers. Bare invocation prints the current version. Flags
    pick the action; --publish bumps + builds + pushes in one shot.
  TXT
  opt :build,   type: :boolean,              desc: 'build the gem (cleans old .gem artifacts first)'
  opt :inc,     type: :boolean,              desc: 'bump .version (see --bump for level)'
  opt :publish, type: :boolean,              desc: 'inc + build + push to RubyGems'
  opt :bump,    default: 'patch',            desc: 'bump level for --inc / --publish: major | minor | patch'
  opt :yes,     type: :boolean, default: false, desc: 'skip publish confirmation prompt'

  proc do |opts|
    if opts[:publish]
      hammer :gem, inc: true, bump: opts[:bump]
      hammer :gem, build: true

      gem_file = Dir.glob('lux-hammer-*.gem').sort.last
      error 'no built gem found' unless gem_file
      error 'cancelled' unless opts[:yes] || yes?("push #{gem_file} to RubyGems?")
      sh "gem push #{gem_file}"
    elsif opts[:build]
      Dir.glob('*.gem').each do |f|
        File.delete(f)
        say "removed #{f}", :gray
      end
      sh 'gem build lux-hammer.gemspec'
    elsif opts[:inc]
      file  = '.version'
      old   = File.read(file).strip
      parts = old.split('.').map(&:to_i)
      error "bad version in #{file}: #{old.inspect}" unless parts.size == 3

      case opts[:bump]
      when 'major' then parts = [parts[0] + 1, 0, 0]
      when 'minor' then parts = [parts[0], parts[1] + 1, 0]
      when 'patch' then parts[2] += 1
      else error "unknown bump: #{opts[:bump]} (major | minor | patch)"
      end

      newv = parts.join('.')
      File.write('.version.prev', "#{old}\n")
      File.write(file, "#{newv}\n")
      say "#{old} -> #{newv}", :green
    else
      say File.read('.version').strip
    end
  end
end

task :gh do
  desc 'Open the GitHub repo in the browser'
  proc { sh 'open https://github.com/dux/hammer' }
end

task :info do
  desc 'Show project stats'
  proc do
    rb_files  = Dir.glob('lib/**/*.rb')
    tst_files = Dir.glob('test/*_test.rb')
    loc       = rb_files.sum { |f| File.read(f).each_line.count }
    tests     = tst_files.sum { |f| File.read(f).scan(/^\s+def test_/).size }
    sha       = `git rev-parse --short HEAD 2>/dev/null`.strip

    say "  lib files: #{rb_files.size} (#{loc} LOC)"
    say "  test files: #{tst_files.size} (#{tests} tests)"
    say "  homepage:  https://github.com/dux/hammer"
    say "  git head:  #{sha}" unless sha.empty?
  end
end
